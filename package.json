{
  "name": "poop-cleaner",
  "version": "0.2.0",
  "description": "A superhero bot that saves group chats from shitty spam reported by good members",
  "main": "bin.js",
  "bin": "bin.js",
  "scripts": {
    "build": "esbuild bin.js --bundle --platform=node --outfile=dist/poop-cleaner.js",
    "start": "node ./bin.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/derogab/poop-cleaner.git"
  },
  "keywords": [
    "telegram-bot",
    "spam-cleaner"
  ],
  "author": "derogab",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/derogab/poop-cleaner/issues"
  },
  "homepage": "https://github.com/derogab/poop-cleaner#readme",
  "dependencies": {
    "dotenv": "17.4.2",
    "grammy": "1.42.0",
    "redis": "5.12.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.27.4",
    "vitest": "^4.1.5"
  }
}
